# Copy to autodev/superagent-auto-improve.env (Windows) or /etc/superagent-auto-improve.env (Linux)
# chmod 600 on Linux. On Windows, restrict file permissions to your user only.
# This file holds real credentials — never commit it.

# ── Required ────────────────────────────────────────────────────────────────

# Path to the cloned AgentApp repository
REPO_DIR=/opt/superagent/AgentApp          # Linux/VPS
# REPO_DIR=D:\Project\OpenSource\AgentApp  # Windows (uncomment and adjust)

# Which branch PRs target — NEVER set to main
BASE_BRANCH=agent-development

# Prefix for per-cycle branches: auto/YYYY-MM-DD-HHmm-<skill>
BRANCH_PREFIX=auto

# Logging directory
LOG_DIR=/var/log/superagent-auto-improve   # Linux
# LOG_DIR=logs\auto-improve               # Windows (relative to REPO_DIR)

# ── Claude Code auth (required for claude-driver) ───────────────────────────
# Use ONE of the two methods:
#   1) Long-lived CI token (recommended — run `claude setup-token` once interactively)
# CLAUDE_CODE_OAUTH_TOKEN=paste-token-here
#   2) Standard Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
# Optional OpenRouter-style proxy:
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_AUTH_TOKEN=sk-or-v1-...
# ANTHROPIC_MODEL=...

# ── SuperAgent CLI driver (required only for run-auto-improve-superagent.*) ─
SA_PROVIDER=anthropic
SA_MODEL=claude-opus-4-5

# ── GitHub (required for auto-PR creation) ──────────────────────────────────
# gh CLI must be authenticated separately: run `gh auth login` once
AUTO_CREATE_PR=true

# ── Loop behavior ────────────────────────────────────────────────────────────
# RECOMMENDED: thin orchestrator that spawns workers in isolated sessions
SKILL=/skill-loop

# once = one worker per outer cycle (best for context)
# round = up to 4 workers per orchestrator session
SKILL_LOOP_MODE=once

# Optional hard cap on MAIN orchestrator turns (workers have separate sessions).
# skill-loop defaults to 25 if unset. Set 0 for unlimited on non-loop skills.
# MAX_TURNS=25

# Workers need full tools; skill-loop main uses a thin default automatically.
# Only override if you know you need more tools on the main session:
# ALLOWED_TOOLS=Read,Grep,Bash,Write,TodoWrite

# Pause file to stop the loop:
#   New-Item .claude\.auto-improve.pause
#   Remove-Item .claude\.auto-improve.pause

# ── Notes ────────────────────────────────────────────────────────────────────
# This file authenticates the loop DRIVER (Claude Code / SuperAgent CLI),
# NOT SuperAgent end-user provider keys (those live in the app settings store).
