# Copy to /etc/superagent-auto-improve.env and set: chmod 600, chown superagent:superagent
# This file holds a real API key — never commit it, never put it inside REPO_DIR.

REPO_DIR=/opt/superagent/AgentApp
BRANCH=side-dev
MAX_TURNS=40
MAX_BUDGET_USD=2.00
LOG_DIR=/var/log/superagent-auto-improve

# Auth for the headless `claude` binary. Use ONE of the two:
#   1) A long-lived CI token (recommended — run `claude setup-token` once,
#      interactively, then paste the result here and delete ANTHROPIC_API_KEY).
# CLAUDE_CODE_OAUTH_TOKEN=paste-token-here
#   2) A standard Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Note: this key authenticates Claude Code (the agent doing the editing).
# It's unrelated to whatever provider API keys you later add *inside*
# SuperAgent for its own end users — those live in SuperAgent's own
# settings store, not here.
