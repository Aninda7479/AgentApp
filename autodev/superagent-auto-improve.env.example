# Copy to /etc/superagent-auto-improve.env (or keep next to run-auto-improve.ps1 on Windows)
# chmod 600 on Linux. On Windows, restrict file permissions to your user only.
# This file holds real credentials — never commit it, never put it inside REPO_DIR.

# ── Required ────────────────────────────────────────────────────────────────

# Path to the cloned AgentApp repository
REPO_DIR=/opt/superagent/AgentApp          # Linux/VPS
# REPO_DIR=D:\Project\OpenSource\AgentApp  # Windows (uncomment and adjust)

# Which branch PRs target — NEVER set to main
BASE_BRANCH=agent-development

# Prefix for per-cycle branches: auto/YYYY-MM-DD-HHmm-<skill>
BRANCH_PREFIX=auto

# Logging directory
LOG_DIR=/var/log/superagent-auto-improve   # Linux
# LOG_DIR=logs\auto-improve               # Windows (relative to REPO_DIR)

# ── Claude Code auth (required for claude-driver) ───────────────────────────
# Use ONE of the two methods:
#   1) Long-lived CI token (recommended — run `claude setup-token` once interactively)
# CLAUDE_CODE_OAUTH_TOKEN=paste-token-here
#   2) Standard Anthropic API key
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=sk-or-v1-4...........
ANTHROPIC_MODEL=tencent/hy3:free
ANTHROPIC_API_KEY=placeholder

# ── SuperAgent CLI driver (required only for run-auto-improve-superagent.sh) ─
# Provider and model the SuperAgent CLI uses to run the loop
SA_PROVIDER=anthropic
SA_MODEL=claude-opus-4-5

# ── GitHub (required for auto-PR creation) ──────────────────────────────────
# gh CLI must be authenticated separately: run `gh auth login` once
# No token needed here — gh CLI reads from its own credential store
AUTO_CREATE_PR=true

# ── Loop behavior ────────────────────────────────────────────────────────────
# Which skill to run (overridden per-timer on Linux, per Task Scheduler task on Windows)
# Values: /auto-improve | /orchestrator-dev | /art-director | /ux-critic
#         /security-auditor | /test-generator | /provider-scout | /dependency-guardian
SKILL=/auto-improve

# Allowed tools for the claude driver (matches skills' allowed-tools frontmatter)
ALLOWED_TOOLS=Read,Grep,Glob,Edit,Write,Bash,WebSearch,WebFetch,TodoWrite

# Note: No MAX_TURNS or MAX_BUDGET_USD — skills run until naturally complete.
# Use the pause file to stop a runaway: touch $REPO_DIR/.claude/.auto-improve.pause

# ── Notes ────────────────────────────────────────────────────────────────────
# This file authenticates Claude Code (the loop driver), NOT SuperAgent's own
# provider connections for end users. SuperAgent's provider API keys live in
# its own settings store — not here.
