# Logs and debug output (as per project structure rules)
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/
jspm_packages/
.pnpm-store/

# Build and distribution outputs
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/

# TypeScript cache and outputs
*.tsbuildinfo
.tscache

# Testing and coverage
coverage/
.nyc_output/
.cypress/

# Environment and sensitive data (NEVER commit tokens or secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# Temporary files and OS clutter
tmp/
temp/
.gemini/
