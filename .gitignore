# Logs and debug output (as per project structure rules)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/
jspm_packages/
.pnpm-store/

# Build and distribution outputs
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/

# TypeScript cache and outputs
*.tsbuildinfo
.tscache

# Testing and coverage
coverage/
.nyc_output/
.cypress/

# Environment and sensitive data (NEVER commit tokens or secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# Temporary files and OS clutter
tmp/
temp/
.gemini/
graphify-out/
.superagent/

# Generated research data dumps (regenerated by root scripts; not part of any
# build — see Unused.md §3). Keep them out of git + Docker context.
research-cache.json
awesome-mcp.md
list.md

# Lily 3D model source assets (large binaries; copied into dist/ at build time).
# If absent from a fresh clone, the built-in Lily gracefully falls back to the
# procedural model, so these are never required to build or run.
packages/desktop/models/lily/v1/*.glb
packages/desktop/models/lily/v1/*.obj
packages/desktop/models/lily/v1/*.png
packages/desktop/models/lily/v1/*.mtl
