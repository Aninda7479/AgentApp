# Logs and debug output (as per project structure rules)
logs
*.log
*.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/
jspm_packages/
.pnpm-store/

# Build and distribution outputs
dist/
dist-release/
dist-release-app/


build/
out/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/

# TypeScript cache and outputs
*.tsbuildinfo
.tscache

# Testing and coverage
coverage/
.nyc_output/
.cypress/

# Environment and sensitive data (NEVER commit tokens or secrets)
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# Temporary files and OS clutter
tmp/
temp/
.gemini/
graphify-out/
.superagent/


# Lily 3D model source assets (large binaries; copied into dist/ at build time).
# If absent from a fresh clone, the built-in Lily gracefully falls back to the
# procedural model, so these are never required to build or run.


# Playwright MCP single-use artifacts (screenshots, page snapshots, console logs) — kept out of git
.playwright
.playwright-mcp

# Local MCP server config (contains a machine-specific Chromium executable path)
.mcp.json

.claude\art-direction.md
.claude\art-director-env.md
.claude\art-director-state.md
