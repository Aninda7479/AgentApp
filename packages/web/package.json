{
  "name": "@superagent/web",
  "version": "0.1.0",
  "description": "SuperAgent web server + responsive SPA (Electron-compatible shared renderer)",
  "main": "dist/server.js",
  "bin": {
    "superagent-web": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "build:client": "node scripts/build.js",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server.js",
    "dev": "npm run build:client && concurrently -n \"tsc,server\" -c \"green,magenta\" \"tsc -w\" \"nodemon --watch dist/server.js dist/server.js\"",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@superagent/core": "^0.1.0",
    "express": "^4.19.2",
    "systeminformation": "^5.31.17",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.14",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
